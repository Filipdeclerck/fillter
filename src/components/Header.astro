---
const base = import.meta.env.BASE_URL;
---
<header class="hero">
  <nav class="nav wrap" aria-label="Hoofdnavigatie">
    <a class="brand" href={base}>
      <img src={`${base}assets/webflow-safe/fillter-logo-white.svg`} alt="Fillter" class="brand-mark" />
      <span>Fillter</span>
    </a>
    <div class="nav-links">
      <a href={`${base}#expertise`}>Onze expertise</a>
      <a href={`${base}#customers`}>Klanten</a>
      <a href={`${base}#contact`}>Contact</a>
    </div>
  </nav>
</header>
