---
const {
  title,
  description,
  icon,
  intro,
  body,
  related,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="hero-page">
  <header class="main-navigation w-nav">
    <div class="w-container">
      <a href="" class="logo-container w-nav-brand">
        <div class="logo-columns w-row">
          <div class="logo-left w-col w-col-3">
        <img src={`${base}assets/webflow-safe/fillter-logo-white.svg`} height="50" alt="Fillter Logo" width="50" class="image" />
          </div>
          <div class="logo-right w-col w-col-9">
            <div class="brand-name">Fillter</div>
          </div>
        </div>
      </a>
      <nav role="navigation" class="nav-menu w-nav-menu">
        <a href={`${base}#expertise`} class="navigation-link w-nav-link">Our expertise</a>
        <a href={`${base}#contact`} class="navigation-link w-nav-link">Contact</a>
      </nav>
    </div>
  </header>
  <div class="container-6 w-container">
    <img height="400" loading="lazy" alt={title} src={`${base}${icon.replace(/^\//, '')}`} class="image-6" />
    <h1 class="discipline-title">{title}</h1>
    <div class="discipline-description w-richtext">
      {intro.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<div id="Discipline-Content" class="section-7">
  <div class="container-9 w-container">
  <h2 class="what-is-header">What is </h2><h2 class="heading-16">{title}</h2><h1 class="heading-18">?</h1>
    <div class="rich-text-block-2 w-richtext">
      {body.map((p) => <p>{p}</p>)}
    </div>
  </div>
</div>

<div id="on-page-Form" class="container-8 w-container">
  <h1 class="discipline-form-title">Questions about </h1><h1 class="discipline-form-title">{title}</h1><h1 class="discipline-form-title">?</h1>
  <p class="paragraph-4">Get in touch without obligation. <br/>We do not treat every question like a sales pitch, and we will not show up asking for “a coffee” unless you ask us to.</p>
  <div class="form-block w-form">
    <div class="contact-card">
      <p class="paragraph-4">Email us directly at <a href="mailto:hello@fillter.be">hello@fillter.be</a>.</p>
    </div>
  </div>
</div>

<div>
  <div class="container-10 w-container">
    <h2 class="heading-17">Explore our other disciplines</h2>
    <div class="w-dyn-list">
      <div role="list" class="w-dyn-items w-row">
        {related.map((item) => (
          <div role="listitem" class="w-dyn-item w-col w-col-4">
      <a href={`${base}${item.href.replace(/^\//, '')}`} class="link-block w-inline-block">
              <img src={`${base}${item.icon.replace(/^\//, '')}`} loading="lazy" alt={item.title} class="image-10" />
              <h3 class="discipline-card">{item.title}</h3>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
