---
const base = import.meta.env.BASE_URL;
---
<section class="wrap hero-grid">
  <div class="hero-content">
    <p class="eyebrow hero-kicker">Digital Transformation Lab</p>
    <h1 class="heading-2">E-commerce &amp; marketplace growth</h1>
    <h1 class="heading-2 nd">without the noise.</h1>
  </div>
  <div class="hero-art" aria-hidden="true">
    <img src={`${base}assets/webflow-safe/digital-transformation-lab-vector.svg`} alt="" />
  </div>
</section>
<section class="wrap hero-lower">
  <p class="paragraph-2 intro-copy">We help brands accelerate online revenue through performance, marketplaces, and scalable e-commerce strategy.</p>
  <div class="hero-actions hero-actions-center">
    <a class="button button-dark" href={`${base}#contact`}>Let&apos;s grow your business</a>
  </div>
</section>
