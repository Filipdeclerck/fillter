---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---
<BaseLayout title="Fillter | Cookie policy" description="Cookie policy for Fillter.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <p class="eyebrow">Legal</p>
      <h1>Cookie policy</h1>
      <p class="lede">
        The original Webflow site used third-party tools such as Google Tag Manager, CookiePro, and Mailchimp. For GitHub Pages, we keep this migration privacy-friendly and minimal. If needed, we can later write a dedicated cookie policy that matches the final analytics and marketing stack.
      </p>
    </section>
  </main>
  <Footer />
</BaseLayout>
