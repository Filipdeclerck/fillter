---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Fillter | E-commerce & marketplace growth"
  description="Fillter helps brands grow through e-commerce consulting, marketplace growth, conversion optimization, performance marketing, marketing automation, and data & analytics."
>
  <Header />
  <main>
    <section class="hero" data-nav-theme="light">
      <Hero />
    </section>
    <section class="section expertise-section" id="expertise" data-nav-theme="dark">
      <div class="wrap">
        <h2>Our expertise</h2>
        <div class="cards">
          <a class="card" href={`${base}disciplines/omni-en-opti-channel-solutions/`}><img src={`${base}assets/webflow-safe/omnichannel.svg`} alt="E-commerce Strategy" /><h3>E-commerce Strategy</h3><p>From audit to roadmap. We identify growth opportunities and translate them into clear, actionable strategy.</p></a>
          <a class="card" href={`${base}disciplines/user-experience-design/`}><img src={`${base}assets/webflow-safe/ux-design.svg`} alt="Marketplace Growth" /><h3>Marketplace Growth</h3><p>Increase revenue through marketplaces without sacrificing margins. We optimize assortment, content, pricing, and performance.</p></a>
          <a class="card" href={`${base}disciplines/conversie-optimalisatie-cro/`}><img src={`${base}assets/webflow-safe/cro.svg`} alt="Conversion Optimization (CRO)" /><h3>Conversion Optimization (CRO)</h3><p>Get more from existing traffic. Data-driven optimizations with direct impact on revenue.</p></a>
          <a class="card" href={`${base}disciplines/crm/`}><img src={`${base}assets/webflow-safe/crm.svg`} alt="Performance Marketing" /><h3>Performance Marketing</h3><p>From acquisition to retention. We optimize channels and campaigns with a focus on profitable growth.</p></a>
          <a class="card" href={`${base}disciplines/ecommerce-management/`}><img src={`${base}assets/webflow-safe/ecommerce.svg`} alt="Marketing Automation" /><h3>Marketing Automation</h3><p>Unlock more revenue from existing customers. We build and optimize flows for activation, retention, and repeat purchases.</p></a>
          <a class="card" href={`${base}disciplines/marketing-automation/`}><img src={`${base}assets/webflow-safe/marketing-automation.svg`} alt="Data &amp; Analytics" /><h3>Data &amp; Analytics</h3><p>Make decisions based on data, not assumptions. We ensure reliable tracking, clear dashboards, and actionable insights.</p></a>
        </div>
      </div>
    </section>
    <section class="section customers-section" id="customers" data-nav-theme="dark">
      <div class="w-container">
        <h2 class="heading-12">Brands we have helped</h2>
        <div class="logo-row">
          <div class="logo-card"><img src={`${base}assets/webflow-safe/hlvo-logo.png`} alt="Het Land van Ooit logo" class="customer-logo" /><div class="customer-name">Het Land van Ooit</div></div>
          <div class="logo-card"><img src={`${base}assets/webflow-safe/slagerij-peeters-govers-logo.jpg`} alt="Slagerij Peeters Govers logo" class="customer-logo" /><div class="customer-name">Slagerij Peeters Govers</div></div>
          <div class="logo-card"><img src={`${base}assets/webflow-safe/psyly-logo.png`} alt="Psyly logo" class="customer-logo" /><div class="customer-name">PSYLY | Sense Know Grow</div></div>
        </div>
      </div>
    </section>
    <section class="contact-us" id="contact" data-nav-theme="light">
      <div class="w-container">
        <div class="contact-grid">
          <div>
            <h2 class="heading-3">Ready to grow your e-commerce?</h2>
            <p class="form-paragraph">We work with brands that want clarity, commercial focus, and measurable growth. If you need a senior partner for e-commerce, marketplaces, or performance, let’s talk.</p>
            <a class="button button-dark" href="mailto:hello@fillter.be">Let&apos;s talk →</a>
          </div>
          <div>
            <div class="contact-card">
              <p class="form-paragraph">Reach us directly at <a href="mailto:hello@fillter.be">hello@fillter.be</a> or use the button on the left.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
