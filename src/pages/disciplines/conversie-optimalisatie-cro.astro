---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/omni-en-opti-channel-solutions/', title: 'Omni en Opti-channel solutions', icon: '/assets/webflow-safe/omnichannel.svg' },
  { href: '/disciplines/user-experience-design/', title: 'User Experience Design', icon: '/assets/webflow-safe/ux-design.svg' },
  { href: '/disciplines/crm/', title: 'Customer Relationship Management (CRM)', icon: '/assets/webflow-safe/crm.svg' },
  { href: '/disciplines/ecommerce-management/', title: 'eCommerce Management', icon: '/assets/webflow-safe/ecommerce.svg' },
  { href: '/disciplines/marketing-automation/', title: 'Marketing Automation', icon: '/assets/webflow-safe/marketing-automation.svg' },
];
---
<BaseLayout title="Fillter | Conversion Optimization (CRO)" description="Fillter is your partner for conversion optimization.">
  <DisciplinePage
    title="Conversion Optimization (CRO)"
    icon="/assets/webflow-safe/cro.svg"
    intro={['How do you get more revenue from existing traffic? Need more qualified leads or a larger email database? We help you turn traffic into measurable growth.']}
    body={['We analyze behavior, map friction, and test improvements with clear hypotheses.', 'Small changes can create large performance gains when the funnel is understood properly.', 'CRO is not guesswork; it is a structured way to improve results.']}
    related={related}
  />
</BaseLayout>
