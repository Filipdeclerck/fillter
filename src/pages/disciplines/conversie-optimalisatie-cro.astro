---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---
<BaseLayout title="Fillter | Conversie Optimalisatie (CRO)" description="Fillter is jouw partner voor Conversie Optimalisatie (CRO) op maat.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <div class="page-panel">
        <p class="eyebrow">Discipline</p>
        <h1>Conversie Optimalisatie (CRO)</h1>
        <p class="lede">Test, leer en verbeter je digitale performance stap voor stap.</p>
      </div>
      <div class="section-heading" style="margin-top: 2rem;">
        <p class="eyebrow">Wat is het?</p>
        <h2>Conversie Optimalisatie (CRO)?</h2>
      </div>
      <p class="lede">We verbeteren pagina’s, flows en content op basis van gedrag, data en heldere hypotheses.</p>
      <div class="actions" style="margin-top: 2rem;">
        <a class="button button-dark" href="/#contact">Neem contact op</a>
        <a class="button button-ghost" href="/#expertise">Terug naar expertise</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
