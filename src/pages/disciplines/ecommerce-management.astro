---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/omni-en-opti-channel-solutions/', title: 'Omni en Opti-channel solutions', icon: '/assets/webflow-safe/omnichannel.svg' },
  { href: '/disciplines/user-experience-design/', title: 'User Experience Design', icon: '/assets/webflow-safe/ux-design.svg' },
  { href: '/disciplines/conversie-optimalisatie-cro/', title: 'Conversie Optimalisatie (CRO)', icon: '/assets/webflow-safe/cro.svg' },
  { href: '/disciplines/crm/', title: 'Customer Relationship Management (CRM)', icon: '/assets/webflow-safe/crm.svg' },
  { href: '/disciplines/marketing-automation/', title: 'Marketing Automation', icon: '/assets/webflow-safe/marketing-automation.svg' },
];
---
<BaseLayout title="Fillter | eCommerce Management" description="Fillter is jouw partner voor eCommerce Management op maat.">
  <DisciplinePage
    title="eCommerce Management"
    icon="/assets/webflow-safe/ecommerce.svg"
    intro={['Online verkopen is niet meer weg te denken uit onze dagelijkse omgeving. Toch hebben veel bedrijven het vandaag moeilijk om hun e-commerce ervaring in te richten.', 'Maar welk e-commerce framework past het best bij jouw product en markt, en hoe begin je er eigenlijk aan?']}
    body={['We bring structure to the webshop operation so the business can grow sustainably.', 'The right ecommerce setup depends on your product, market and internal workflow.', 'Management means steering both performance and day-to-day execution.']}
    related={related}
  />
</BaseLayout>
