---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---
<BaseLayout title="Fillter | eCommerce Management" description="Fillter is jouw partner voor eCommerce Management op maat.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <div class="page-panel">
        <p class="eyebrow">Discipline</p>
        <h1>eCommerce Management</h1>
        <p class="lede">Regie op je webshop, processen, platform en commerciële prioriteiten.</p>
      </div>
      <div class="section-heading" style="margin-top: 2rem;">
        <p class="eyebrow">Wat is het?</p>
        <h2>eCommerce Management?</h2>
      </div>
      <p class="lede">We zorgen dat je webshop niet alleen draait, maar ook commercieel gezond groeit.</p>
      <div class="actions" style="margin-top: 2rem;">
        <a class="button button-dark" href="/#contact">Neem contact op</a>
        <a class="button button-ghost" href="/#expertise">Terug naar expertise</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
