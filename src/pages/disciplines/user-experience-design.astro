---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/omni-en-opti-channel-solutions/', title: 'Omni en Opti-channel solutions', icon: '/assets/webflow-safe/omnichannel.svg' },
  { href: '/disciplines/conversie-optimalisatie-cro/', title: 'Conversie Optimalisatie (CRO)', icon: '/assets/webflow-safe/cro.svg' },
  { href: '/disciplines/crm/', title: 'Customer Relationship Management (CRM)', icon: '/assets/webflow-safe/crm.svg' },
  { href: '/disciplines/ecommerce-management/', title: 'eCommerce Management', icon: '/assets/webflow-safe/ecommerce.svg' },
  { href: '/disciplines/marketing-automation/', title: 'Marketing Automation', icon: '/assets/webflow-safe/marketing-automation.svg' },
];
---
<BaseLayout title="Fillter | User Experience Design" description="Fillter is jouw partner voor User Experience Design op maat.">
  <DisciplinePage
    title="User Experience Design"
    icon="/assets/webflow-safe/ux-design.svg"
    intro={['Sluit jouw customer of gebruikerservaring aan bij de verwachtingen van je klant? Een goede gebruikerservaring leidt niet uitsluitend naar meer verkoop, maar zorgt er voor dat klanten zich goed voelen bij je merk.']}
    body={['UX helps people find what they need quickly and with confidence.', 'We structure interfaces so the journey feels natural on desktop and mobile.', 'Better experience means fewer drop-offs and clearer value for the user.']}
    related={related}
  />
</BaseLayout>
