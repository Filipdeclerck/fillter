---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/user-experience-design/', title: 'User Experience Design', icon: '/assets/webflow-safe/ux-design.svg' },
  { href: '/disciplines/conversie-optimalisatie-cro/', title: 'Conversie Optimalisatie (CRO)', icon: '/assets/webflow-safe/cro.svg' },
  { href: '/disciplines/crm/', title: 'Customer Relationship Management (CRM)', icon: '/assets/webflow-safe/crm.svg' },
  { href: '/disciplines/ecommerce-management/', title: 'eCommerce Management', icon: '/assets/webflow-safe/ecommerce.svg' },
  { href: '/disciplines/marketing-automation/', title: 'Marketing Automation', icon: '/assets/webflow-safe/marketing-automation.svg' },
];
---
<BaseLayout title="Fillter | Omni and Opti-channel solutions" description="Fillter is your partner for omni and opti-channel solutions.">
  <DisciplinePage
    title="Omni and Opti-channel solutions"
    icon="/assets/webflow-safe/omnichannel.svg"
    intro={[
      'Selling in-store with home delivery? Letting customers pay online and return at the store? People expect a seamless omnichannel experience.',
      'Every touchpoint a customer encounters must work together. An opti-channel view is essential for sustainable growth.',
    ]}
    body={[
      'In an omnichannel setup, display, search, social, referral, email, and mobile can all play a distinct role in the customer journey.',
      'Retailers need to connect online and offline channels to avoid fragmented campaigns. Messaging, promotions, and language should stay consistent across every touchpoint.',
      'Omnichannel solutions also help brands tighten control over inventory, pricing, and channel performance so each channel stays current and profitable.',
    ]}
    related={related}
  />
</BaseLayout>
