---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---
<BaseLayout title="Fillter | Omni en Opti-channel solutions" description="Fillter is jouw partner voor Omni en Opti-channel solutions op maat.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <div class="page-panel">
        <p class="eyebrow">Discipline</p>
        <h1>Omni en Opti-channel solutions</h1>
        <p class="lede">Naadloze ervaringen tussen online, winkel en andere touchpoints.</p>
      </div>
      <div class="section-heading" style="margin-top: 2rem;">
        <p class="eyebrow">Wat is het?</p>
        <h2>Omni en Opti-channel solutions?</h2>
      </div>
      <p class="lede">We helpen klanten en kanalen op elkaar afstemmen zodat je merk overal consistent aanvoelt.</p>
      <div class="actions" style="margin-top: 2rem;">
        <a class="button button-dark" href="/#contact">Neem contact op</a>
        <a class="button button-ghost" href="/#expertise">Terug naar expertise</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
