---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---
<BaseLayout title="Fillter | Customer Relationship Management (CRM)" description="Fillter is jouw partner voor Customer Relationship Management (CRM) op maat.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <div class="page-panel">
        <p class="eyebrow">Discipline</p>
        <h1>Customer Relationship Management (CRM)</h1>
        <p class="lede">Klantdata, processen en integraties die betrouwbaar samenwerken.</p>
      </div>
      <div class="section-heading" style="margin-top: 2rem;">
        <p class="eyebrow">Wat is het?</p>
        <h2>Customer Relationship Management (CRM)?</h2>
      </div>
      <p class="lede">We helpen je data en tools netjes te verbinden zodat klantinformatie bruikbaar en compliant blijft.</p>
      <div class="actions" style="margin-top: 2rem;">
        <a class="button button-dark" href="/#contact">Neem contact op</a>
        <a class="button button-ghost" href="/#expertise">Terug naar expertise</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
