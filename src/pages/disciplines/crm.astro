---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/omni-en-opti-channel-solutions/', title: 'Omni en Opti-channel solutions', icon: '/assets/webflow-safe/omnichannel.svg' },
  { href: '/disciplines/user-experience-design/', title: 'User Experience Design', icon: '/assets/webflow-safe/ux-design.svg' },
  { href: '/disciplines/conversie-optimalisatie-cro/', title: 'Conversie Optimalisatie (CRO)', icon: '/assets/webflow-safe/cro.svg' },
  { href: '/disciplines/ecommerce-management/', title: 'eCommerce Management', icon: '/assets/webflow-safe/ecommerce.svg' },
  { href: '/disciplines/marketing-automation/', title: 'Marketing Automation', icon: '/assets/webflow-safe/marketing-automation.svg' },
];
---
<BaseLayout title="Fillter | Customer Relationship Management (CRM)" description="Fillter is your partner for CRM strategy and execution.">
  <DisciplinePage
    title="Customer Relationship Management (CRM)"
    icon="/assets/webflow-safe/crm.svg"
    intro={['Keeping all your customer information in one clear place sounds simple, but it rarely is.', 'Data regulations and software synchronisation can make CRM implementation more complex than expected.']}
    body={['CRM becomes powerful when data, process, and governance work together.', 'We help connect systems so customer information remains usable and compliant.', 'The goal is one reliable customer view that teams can actually work with.']}
    related={related}
  />
</BaseLayout>
