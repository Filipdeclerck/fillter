---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisciplinePage from '../../components/DisciplinePage.astro';
import '../../styles/global.css';
const related = [
  { href: '/disciplines/omni-en-opti-channel-solutions/', title: 'Omni en Opti-channel solutions', icon: '/assets/webflow-safe/omnichannel.svg' },
  { href: '/disciplines/user-experience-design/', title: 'User Experience Design', icon: '/assets/webflow-safe/ux-design.svg' },
  { href: '/disciplines/conversie-optimalisatie-cro/', title: 'Conversie Optimalisatie (CRO)', icon: '/assets/webflow-safe/cro.svg' },
  { href: '/disciplines/crm/', title: 'Customer Relationship Management (CRM)', icon: '/assets/webflow-safe/crm.svg' },
  { href: '/disciplines/ecommerce-management/', title: 'eCommerce Management', icon: '/assets/webflow-safe/ecommerce.svg' },
];
---
<BaseLayout title="Fillter | Marketing Automation" description="Fillter is jouw partner voor Marketing Automation op maat.">
  <DisciplinePage
    title="Marketing Automation"
    icon="/assets/webflow-safe/marketing-automation.svg"
    intro={['Wil je graag sneller leads verzamelen, efficienter communiceren met je klanten of die vervelende repetitieve handelingen overlaten aan een digitale toepassing?', 'Onze Laboranten bieden een hele reeks automation tools en experimenten aan, om jouw klantreis te automatiseren.']}
    body={['Automation helps you do more with less manual effort.', 'We design flows that save time while making communication more relevant.', 'The best automation is invisible to the user and useful for the team.']}
    related={related}
  />
</BaseLayout>
