---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
---
<BaseLayout title="Fillter | Marketing Automation" description="Fillter is jouw partner voor Marketing Automation op maat.">
  <Header />
  <main class="page-main">
    <section class="wrap section">
      <div class="page-panel">
        <p class="eyebrow">Discipline</p>
        <h1>Marketing Automation</h1>
        <p class="lede">Minder repetitief werk, meer schaalbare klantcommunicatie.</p>
      </div>
      <div class="section-heading" style="margin-top: 2rem;">
        <p class="eyebrow">Wat is het?</p>
        <h2>Marketing Automation?</h2>
      </div>
      <p class="lede">We zetten automatisatie op die tijd bespaart, opvolging verbetert en resultaten meetbaar maakt.</p>
      <div class="actions" style="margin-top: 2rem;">
        <a class="button button-dark" href="/#contact">Neem contact op</a>
        <a class="button button-ghost" href="/#expertise">Terug naar expertise</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
